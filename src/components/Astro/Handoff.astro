---
import { UserCircle2, Bot } from 'lucide-react';
---
<section id="handoff-section" class="relative bg-zinc-950 py-32 text-zinc-50 overflow-hidden min-h-[90vh] flex items-center">
  <div class="max-w-[1400px] mx-auto px-6 w-full grid grid-cols-1 md:grid-cols-2 gap-16 lg:gap-24 items-center">
    
    <!-- Text Content -->
    <div class="space-y-6 z-10">
      <h2 class="text-4xl md:text-5xl lg:text-6xl font-semibold tracking-tight leading-[1.05]">Handoff Inteligente.</h2>
      <p class="text-lg text-zinc-400 font-light max-w-lg">Toma el control cuando sea necesario. Intervención en tiempo real sin fricciones ni esperas.</p>
      <div class="inline-flex items-center gap-3 bg-zinc-900 border border-zinc-800 rounded-full py-2 px-4 mt-4">
        <div class="w-2 h-2 rounded-full bg-emerald-500 animate-pulse"></div>
        <span class="text-sm font-medium text-zinc-300">Agentes Humanos en línea</span>
      </div>
    </div>

    <!-- Chat Simulation -->
    <div id="handoff-chat-container" class="relative w-full max-w-md mx-auto aspect-[4/5] bg-zinc-900 border border-zinc-800 rounded-[2rem] p-6 flex flex-col gap-4 shadow-2xl">
      
      <!-- User message -->
      <div class="self-end bg-zinc-800 border border-zinc-700 p-4 rounded-2xl rounded-tr-sm max-w-[85%] text-sm text-zinc-100 shadow-sm font-light leading-relaxed">
        Necesito hablar con un asesor sobre mi factura, por favor.
      </div>

      <!-- Bot message (Will disappear) -->
      <div id="bot-typing" class="self-start bg-zinc-950 border border-zinc-800 p-4 rounded-2xl rounded-tl-sm max-w-[85%] text-sm flex gap-3 items-center text-zinc-400 opacity-100 shadow-sm font-light">
        <Bot size={18} className="text-zinc-500" strokeWidth={1.5} /> <span class="animate-pulse">Escribiendo...</span>
      </div>

      <!-- System Notification (Hidden initially) -->
      <div id="handoff-alert" class="w-full flex justify-center py-4 opacity-0 scale-90">
        <div class="bg-zinc-800 border border-zinc-700 text-zinc-300 text-xs px-4 py-2 rounded-full flex items-center gap-2 shadow-sm font-medium">
           <UserCircle2 size={14} strokeWidth={1.5} /> Carlos (Agente) se ha unido al chat
        </div>
      </div>

      <!-- Human Agent Message (Hidden initially) -->
      <div id="human-reply" class="self-start bg-zinc-100 border border-zinc-200 p-4 rounded-2xl rounded-tl-sm max-w-[85%] text-sm text-zinc-950 opacity-0 translate-y-4 shadow-sm font-light leading-relaxed">
        Hola, soy Carlos. Ya revisé tu historial, te ayudo a resolver el problema con tu factura ahora mismo.
      </div>
      
    </div>
  </div>
</section>

<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  gsap.registerPlugin(ScrollTrigger);

  const initHandoffAnimations = () => {
    const tl = gsap.timeline({
      scrollTrigger: {
        trigger: '#handoff-section',
        start: 'top center',
        toggleActions: 'play none none reverse', // Play on enter, reverse on leave back
      }
    });

    tl.to('#bot-typing', {
      opacity: 0,
      height: 0,
      margin: 0,
      padding: 0,
      duration: 0.5,
      delay: 0.5
    })
    .to('#handoff-alert', {
      opacity: 1,
      scale: 1,
      duration: 0.5,
      ease: 'back.out(1.7)'
    })
    .to('#human-reply', {
      opacity: 1,
      y: 0,
      duration: 0.5,
      ease: 'power3.out'
    }, "+=0.3");
  };

  initHandoffAnimations();
</script>
