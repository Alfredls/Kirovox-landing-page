---
import Button from './Button.astro';
---
<section id="hero-section" class="relative min-h-[100dvh] bg-white flex flex-col justify-center pt-24 pb-12 overflow-hidden border-b border-zinc-100">
  
  <!-- Background Decor (Concentric circles & particles) -->
  <div class="absolute inset-0 z-0 pointer-events-none overflow-hidden opacity-70">
    <svg class="w-full h-full" xmlns="http://www.w3.org/2000/svg">
      <!-- Círculos concéntricos en la esquina inferior derecha -->
      <!-- Centro en 100%, 100% asegura que solo veamos el cuarto superior izquierdo del círculo -->
      <!-- 2 Anillos adicionales más grandes -->
      <!-- El anillo de 100vh tocará exactamente el borde superior de la pantalla -->
      <!-- Aumentado el color en el centro y más claro hacia afuera -->
      <!-- Todos los anillos mantienen exactamente el mismo grosor (20vh de diferencia) -->
      <circle cx="100%" cy="100%" style="r: 120vh;" fill="#ecfdf5" opacity="0.15" />
      <circle cx="100%" cy="100%" style="r: 100vh;" fill="#ecfdf5" opacity="0.3" />
      <circle cx="100%" cy="100%" style="r: 80vh;" fill="#d1fae5" opacity="0.4" />
      <circle cx="100%" cy="100%" style="r: 60vh;" fill="#a7f3d0" opacity="0.4" />
      <circle cx="100%" cy="100%" style="r: 40vh;" fill="#6ee7b7" opacity="0.5" />
      <circle cx="100%" cy="100%" style="r: 20vh;" fill="#34d399" opacity="0.5" />
      
      <!-- Partículas (Puntos dispersos por toda la pantalla usando porcentajes) -->
      <!-- Originales -->
      <circle cx="15%" cy="20%" r="12" fill="#a7f3d0" opacity="0.5" />
      <circle cx="8%" cy="60%" r="6" fill="#6ee7b7" opacity="0.6" />
      <circle cx="35%" cy="80%" r="15" fill="#34d399" opacity="0.3" />
      <circle cx="45%" cy="15%" r="8" fill="#d1fae5" opacity="0.8" />
      <circle cx="65%" cy="30%" r="10" fill="#6ee7b7" opacity="0.5" />
      <circle cx="75%" cy="70%" r="14" fill="#a7f3d0" opacity="0.4" />
      <circle cx="85%" cy="15%" r="12" fill="#34d399" opacity="0.3" />
      <circle cx="95%" cy="50%" r="7" fill="#6ee7b7" opacity="0.4" />
      <circle cx="55%" cy="90%" r="9" fill="#d1fae5" opacity="0.7" />
      <circle cx="25%" cy="40%" r="11" fill="#a7f3d0" opacity="0.5" />
      <circle cx="5%" cy="85%" r="8" fill="#34d399" opacity="0.4" />
      <circle cx="80%" cy="90%" r="12" fill="#6ee7b7" opacity="0.5" />
      <circle cx="50%" cy="50%" r="5" fill="#a7f3d0" opacity="0.6" />
      <circle cx="25%" cy="95%" r="10" fill="#d1fae5" opacity="0.5" />
      <!-- Nuevas partículas adicionales -->
      <circle cx="10%" cy="30%" r="9" fill="#10b981" opacity="0.3" />
      <circle cx="20%" cy="75%" r="7" fill="#34d399" opacity="0.5" />
      <circle cx="30%" cy="15%" r="13" fill="#6ee7b7" opacity="0.4" />
      <circle cx="40%" cy="65%" r="6" fill="#a7f3d0" opacity="0.7" />
      <circle cx="60%" cy="10%" r="11" fill="#34d399" opacity="0.3" />
      <circle cx="70%" cy="50%" r="14" fill="#10b981" opacity="0.2" />
      <circle cx="85%" cy="35%" r="8" fill="#6ee7b7" opacity="0.5" />
      <circle cx="90%" cy="75%" r="10" fill="#a7f3d0" opacity="0.6" />
      <circle cx="15%" cy="90%" r="12" fill="#34d399" opacity="0.4" />
      <circle cx="35%" cy="95%" r="7" fill="#6ee7b7" opacity="0.6" />
      <circle cx="65%" cy="85%" r="15" fill="#10b981" opacity="0.2" />
      <circle cx="80%" cy="5%" r="9" fill="#a7f3d0" opacity="0.5" />
      <circle cx="45%" cy="40%" r="8" fill="#34d399" opacity="0.4" />
      <circle cx="55%" cy="70%" r="11" fill="#6ee7b7" opacity="0.5" />
      <circle cx="95%" cy="25%" r="6" fill="#10b981" opacity="0.3" />
      <circle cx="5%" cy="45%" r="14" fill="#a7f3d0" opacity="0.4" />
    </svg>
  </div>

  <div class="max-w-[1400px] w-full mx-auto px-6 grid grid-cols-1 lg:grid-cols-2 gap-4 lg:gap-12 items-center relative z-10">
    
    <!-- Text Content (Left) -->
    <div id="hero-text-container" class="relative z-20 flex flex-col max-w-2xl opacity-0 translate-y-8">
      <div class="inline-block px-3 py-1 mb-6 text-xs font-semibold tracking-wider text-emerald-700 uppercase bg-emerald-50 border border-emerald-100 rounded-full w-fit">
        Atención al cliente 24/7
      </div>
      <h1 class="text-5xl md:text-7xl font-semibold tracking-tight text-brand-deep mb-6 leading-[1.05]">
        Automatiza, <br><span class="text-zinc-500 font-thin text-3xl md:text-5xl">la informacion de tu empresa.</span>
      </h1>
      <p class="text-lg text-zinc-600 font-light mb-8 max-w-[60ch] leading-relaxed">
        Sube tus manuales, conecta tus canales y deja que nuestro sistema de <b class="font-bold text-brand-deep">chatbot</b> atienda a tus clientes <b class="font-bold text-brand-deep"> de manera instantánea y precisa.</b> Toda la informacion para tus clientes en un solo lugar, <b class="font-bold text-brand-deep"> siempre actualizada.</b>
      </p>


      <div class="flex items-center gap-4">
        <Button href="#pricing" variant="primary" class="group">
          Comenzar prueba 
          <svg class="w-4 h-4 ml-2 group-hover:translate-x-1 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3" />
          </svg>
        </Button>
      </div>
    </div>

    <!-- Visual Content (Right) - 3D Carousel & Mobile Marquee -->
    <div id="hero-visual" class="relative w-full h-[260px] md:h-[400px] lg:h-[800px] flex items-center justify-center lg:mt-0 opacity-0 overflow-hidden lg:overflow-visible">
      
      <!-- Mobile Auto-Scrolling Marquee (lg:hidden) -->
      <div class="lg:hidden w-full absolute top-1/2 -translate-y-1/2 mask-edges">
        <div class="flex gap-4 w-max animate-marquee hover:[animation-play-state:paused]">
          {[
            '1.png','2.png','3.png','4.png','5.png',
            '1.png','2.png','3.png','4.png','5.png'
          ].map((img) => (
            <figure class="flex-none w-[260px] sm:w-[320px] rounded-[18px] overflow-hidden shadow-xl border border-zinc-200/60 bg-white">
              <img src={`/images/img${img}`} alt="Gallery image" class="w-full h-auto object-cover pointer-events-none" />
            </figure>
          ))}
        </div>
      </div>

      <!-- Desktop 3D Flow (lg:block) -->
      <div class="hidden lg:block absolute inset-0 w-full h-full pointer-events-none" style="perspective: 3400px;">
        <div class="absolute inset-0 w-full h-full" style="transform-style: preserve-3d; transform: rotateX(3deg) rotateY(-4deg);">
          {[
            '1.png','2.png','3.png','4.png','5.png'
          ].map((img) => (
            <figure class="hero-3d-card absolute left-1/2 top-1/2 w-[62%] rounded-[18px] overflow-hidden shadow-[0_30px_60px_-15px_rgba(0,0,0,0.3)] border border-zinc-200/80 bg-white will-change-transform" style="opacity: 0;">
              <img src={`/images/img${img}`} alt="Gallery image" class="w-full h-auto object-cover" />
            </figure>
          ))}
        </div>
      </div>

    </div>
  </div>
</section>

<script>
  import { gsap } from 'gsap';

  const initHeroAnimations = () => {
    // Simple, elegant entrance animation. No scroll-hijacking for the hero.
    const tl = gsap.timeline({ defaults: { ease: 'power3.out' } });
    
    tl.to('#hero-text-container', {
      autoAlpha: 1,
      y: 0,
      duration: 1.2,
      delay: 0.2
    })
    .to('#hero-visual', {
      autoAlpha: 1,
      duration: 1.2
    }, "-=1.0");

    // Optimized infinite 3D Flow Animation for Desktop
    const cards = gsap.utils.toArray('.hero-3d-card') as HTMLElement[];
    if (cards.length > 0) {
      const totalDuration = 24; // Transición más lenta (antes 12)
      const cardTimelines: gsap.core.Timeline[] = [];

      cards.forEach((card, i) => {
        const cardTl = gsap.timeline({ repeat: -1 });
        
        // Estado inicial (Atrás a la izquierda y más arriba)
        gsap.set(card, {
          xPercent: -80, // Viene desde más a la izquierda
          yPercent: -350,
          z: -1000,
          rotationX: 4,
          rotationY: -3,
          scale: 0.4,
          opacity: 0
        });

        // 4 Fases para lograr el trayecto en forma de semicírculo (baja, va a la derecha, y sube)
        cardTl
          // Fase 1: Entrada hacia el centro
          .to(card, {
            xPercent: -60,
            yPercent: -15,
            z: 240,
            rotationX: 2,
            rotationY: 0,
            scale: 1.15,
            opacity: 1,
            duration: totalDuration * 0.35, // 35% del tiempo
            ease: "none"
          })
          // Fase 2: Al inicio de salir, va BAJANDO (la curva inferior del círculo, sin cortarse)
          .to(card, {
            xPercent: 10,       // Se mueve un poco a la derecha
            yPercent: 65,       // Baja menos profundo para no cortarse (antes 150)
            z: 100,             // Empieza a alejarse hacia el fondo
            rotationX: 4,
            rotationY: 5,
            scale: 0.9,         // Pierde un poco de tamaño
            opacity: 0.8,       // Aún muy visible
            duration: totalDuration * 0.20, // 20% del tiempo
            ease: "none"
          })
          // Fase 3: Sigue saliendo hacia la DERECHA
          .to(card, {
            xPercent: 100,      // Avanza hacia la derecha
            yPercent: 40,       // Ya empieza a subir ligeramente la curva (antes 100)
            z: -200,            // Más al fondo
            rotationX: 6,
            rotationY: 12,
            scale: 0.65,        // Se hace más pequeña
            opacity: 0.4,       // Pierde más opacidad
            duration: totalDuration * 0.25, // 25% del tiempo
            ease: "none"
          })
          // Fase 4: Llega a un punto donde va SUBIENDO y sale de pantalla
          .to(card, {
            xPercent: 180,      // Muy a la derecha, sale de pantalla
            yPercent: -50,      // Sube completando el círculo
            z: -800,            // Desaparece en el fondo
            rotationX: 10,
            rotationY: 20,
            scale: 0.3,         // Muy pequeña
            opacity: 0,         // Opacidad cero
            duration: totalDuration * 0.20, // 20% del tiempo
            ease: "none"
          });

        // Distribuimos las animaciones equitativamente para que sea un flujo continuo
        cardTl.progress(i / cards.length);
        cardTimelines.push(cardTl);
      });

      // Interacción de Arrastre (Drag)
      const heroVisual = document.getElementById('hero-visual');
      if (heroVisual) {
        let isDragging = false;
        let startX = 0;
        
        // Cambiamos el puntero a "manito"
        heroVisual.style.cursor = 'grab';

        const onPointerDown = (e: PointerEvent) => {
          isDragging = true;
          startX = e.clientX;
          heroVisual.style.cursor = 'grabbing';
          // Pausa la animación solo al sostener el click
          cardTimelines.forEach(t => t.pause());
        };

        const onPointerMove = (e: PointerEvent) => {
          if (!isDragging) return;
          
          const deltaX = e.clientX - startX;
          // Sensibilidad del arrastre
          const timeAdjustment = deltaX * -0.015; 
          
          cardTimelines.forEach(t => {
            let newTime = t.time() + timeAdjustment;
            // Para evitar que se acoplen (overlap) al ir hacia atrás, 
            // envolvemos el tiempo en un ciclo seguro de 0 a totalDuration
            newTime = (newTime % totalDuration + totalDuration) % totalDuration;
            t.time(newTime);
          });
          
          startX = e.clientX;
        };

        const onPointerUp = () => {
          if (!isDragging) return;
          isDragging = false;
          heroVisual.style.cursor = 'grab';
          // Reanuda la animación al soltar
          cardTimelines.forEach(t => t.play());
        };

        heroVisual.addEventListener('pointerdown', onPointerDown);
        window.addEventListener('pointermove', onPointerMove);
        window.addEventListener('pointerup', onPointerUp);
        window.addEventListener('pointercancel', onPointerUp);
      }
    }
  };

  initHeroAnimations();
</script>

<style>
  .animate-marquee {
    animation: marquee 40s linear infinite;
  }
  @keyframes marquee {
    0% { transform: translateX(0%); }
    100% { transform: translateX(-50%); }
  }
  .mask-edges {
    mask-image: linear-gradient(to right, transparent, black 5%, black 95%, transparent);
    -webkit-mask-image: linear-gradient(to right, transparent, black 5%, black 95%, transparent);
  }
</style>
