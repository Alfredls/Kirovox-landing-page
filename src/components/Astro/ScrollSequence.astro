---
---
<section id="scroll-sequence" class="relative w-full bg-zinc-950 overflow-hidden">
  
  <!-- Pinned Container -->
  <div class="seq-pinned w-full h-screen relative overflow-hidden flex items-center justify-center">
    
    <!-- Backgrounds / Slides -->
    
    <!-- SLIDE 1: Dark -->
    <div class="seq-bg seq-bg-1 absolute inset-0 bg-zinc-950 flex flex-col md:flex-row items-center justify-center md:justify-start px-6 md:pl-32">
        <!-- Giant Background Number -->
        <h2 class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 md:translate-x-0 md:left-10 text-[60vw] md:text-[35vw] font-black text-white/5 leading-none select-none">01</h2>
        <!-- Content -->
        <div class="relative z-10 w-full md:w-[400px] md:ml-auto md:mr-32 text-zinc-50 text-center md:text-left mt-[300px] md:mt-0">
            <h3 class="text-4xl md:text-6xl font-semibold mb-4 tracking-tight leading-[1.05]">Captura <br/><span class="text-zinc-500">Leads</span></h3>
            <p class="text-lg md:text-xl font-light text-zinc-400">
              Instala Kirovox en tu landing page en segundos. Convierte visitantes en prospectos calificados automáticamente 24/7.
            </p>
        </div>
    </div>

    <!-- SLIDE 2: Light -->
    <div class="seq-bg seq-bg-2 absolute inset-0 bg-zinc-100 flex flex-col md:flex-row items-center justify-center md:justify-start px-6 md:pl-32 opacity-0">
        <!-- Giant Background Number -->
        <h2 class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 md:translate-x-0 md:left-10 text-[60vw] md:text-[35vw] font-black text-black/5 leading-none select-none">02</h2>
        <!-- Content -->
        <div class="relative z-10 w-full md:w-[400px] text-zinc-950 text-center md:text-left mb-[300px] md:mb-0">
            <h3 class="text-4xl md:text-6xl font-semibold mb-4 tracking-tight leading-[1.05]">IA que <br/><span class="text-zinc-500">Aprende</span></h3>
            <p class="text-lg md:text-xl font-light text-zinc-600">
              Sube tus PDFs y manuales. Nuestro modelo genera respuestas precisas sin alucinaciones, ahorrando horas de soporte.
            </p>
        </div>
    </div>

    <!-- SLIDE 3: Darker -->
    <div class="seq-bg seq-bg-3 absolute inset-0 bg-zinc-900 flex flex-col md:flex-row items-center justify-center md:justify-start px-6 md:pl-32 opacity-0">
        <!-- Giant Background Number -->
        <h2 class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 md:translate-x-0 md:left-10 text-[60vw] md:text-[35vw] font-black text-white/5 leading-none select-none">03</h2>
        <!-- Content -->
        <div class="relative z-10 w-full md:w-[400px] md:ml-auto md:mr-32 text-zinc-50 text-center md:text-left mt-[300px] md:mt-0">
            <h3 class="text-4xl md:text-6xl font-semibold mb-4 tracking-tight leading-[1.05]">Traspaso <br/><span class="text-zinc-500">Humano</span></h3>
            <p class="text-lg md:text-xl font-light text-zinc-400">
              Cuando la IA no es suficiente, la conversación se transfiere a tu equipo humano con todo el historial del cliente intacto.
            </p>
        </div>
    </div>


    <!-- ============================================== -->
    <!-- THE 2.5D FLOATING PHONE (Center Stage)        -->
    <!-- ============================================== -->
    <div class="absolute inset-0 z-50 flex items-center justify-center pointer-events-none" style="perspective: 1200px;">
        
        <div class="scroll-seq-phone relative w-[260px] md:w-[320px] h-[540px] md:h-[660px] bg-zinc-950 rounded-[3rem] border-[8px] border-zinc-900 shadow-2xl overflow-hidden flex flex-col" style="transform-style: preserve-3d; box-shadow: -20px 20px 60px rgba(0,0,0,0.5);">
            
            <!-- Camera Notch -->
            <div class="absolute top-0 left-1/2 -translate-x-1/2 w-[100px] h-[24px] bg-zinc-900 rounded-b-[1rem] z-50"></div>
            <!-- Side Buttons -->
            <div class="absolute top-[100px] -left-[10px] w-[2px] h-[30px] bg-zinc-800 rounded-l-md"></div>
            <div class="absolute top-[150px] -left-[10px] w-[2px] h-[50px] bg-zinc-800 rounded-l-md"></div>
            <div class="absolute top-[120px] -right-[10px] w-[2px] h-[40px] bg-zinc-800 rounded-r-md"></div>

            <!-- SCREENS -->
            
            <!-- Screen 1: Chat Widget -->
            <div class="phone-screen phone-screen-1 absolute inset-0 bg-zinc-50 flex flex-col">
                <div class="h-16 bg-white border-b border-zinc-200 flex items-end justify-center pb-3 text-zinc-950 font-medium text-sm shadow-sm z-10">Soporte Bot</div>
                <div class="flex-1 p-4 flex flex-col justify-end space-y-3 pb-8">
                    <div class="bg-white p-3 rounded-2xl rounded-tl-sm shadow-sm text-xs border border-zinc-200 self-start w-[85%] text-zinc-700">Hola, ¿En qué puedo ayudarte hoy?</div>
                    <div class="bg-zinc-950 p-3 rounded-2xl rounded-tr-sm shadow-sm text-xs text-white self-end w-[85%] font-light">Quiero cotizar un plan.</div>
                    <div class="bg-white p-3 rounded-2xl rounded-tl-sm shadow-sm text-xs border border-zinc-200 self-start w-[85%] text-zinc-700">¡Claro! Tenemos planes desde $29/mes.</div>
                </div>
            </div>

            <!-- Screen 2: PDF RAG -->
            <div class="phone-screen phone-screen-2 absolute inset-0 bg-zinc-900 opacity-0 flex flex-col">
                <div class="h-16 bg-zinc-950 flex items-end justify-center pb-3 text-white font-medium text-sm border-b border-zinc-800 z-10">Conocimiento IA</div>
                <div class="flex-1 p-4 flex flex-col space-y-3 pt-6">
                    <div class="w-full bg-zinc-800 p-3 rounded-xl flex items-center gap-3 border border-zinc-700">
                        <div class="w-8 h-8 bg-zinc-100 rounded-lg flex items-center justify-center text-zinc-900 font-bold text-xs">PDF</div>
                        <div class="flex-1">
                            <div class="h-2 w-20 bg-zinc-600 rounded mb-1"></div>
                            <div class="h-2 w-12 bg-zinc-700 rounded"></div>
                        </div>
                    </div>
                    <div class="w-full bg-zinc-800 p-3 rounded-xl flex items-center gap-3 border border-zinc-700">
                        <div class="w-8 h-8 bg-zinc-100 rounded-lg flex items-center justify-center text-zinc-900 font-bold text-xs">DOC</div>
                        <div class="flex-1">
                            <div class="h-2 w-24 bg-zinc-600 rounded mb-1"></div>
                            <div class="h-2 w-16 bg-zinc-700 rounded"></div>
                        </div>
                    </div>
                     <div class="mt-6 bg-zinc-950 p-4 rounded-xl border border-zinc-800 shadow-inner">
                        <p class="text-zinc-500 text-[10px] mb-2 uppercase tracking-wider font-semibold">Respuesta Generada</p>
                        <p class="text-zinc-300 text-xs leading-relaxed font-light">Según el manual v2.0, el proceso de instalación requiere permisos de admin.</p>
                    </div>
                </div>
            </div>

            <!-- Screen 3: Human Agent -->
            <div class="phone-screen phone-screen-3 absolute inset-0 bg-zinc-50 opacity-0 flex flex-col">
                <div class="h-16 bg-white border-b border-zinc-200 flex items-end justify-center pb-3 text-zinc-950 font-medium text-sm shadow-sm z-10">Agente Carlos</div>
                <div class="flex-1 p-4 flex flex-col space-y-3 justify-end pb-8">
                    <div class="text-center text-[10px] text-zinc-400 font-bold uppercase tracking-wider my-2">Chat transferido</div>
                    <div class="bg-zinc-950 p-3 rounded-2xl rounded-tl-sm shadow-sm text-xs text-white self-start w-[85%] font-light">
                        Hola, soy Carlos de soporte. Veo que tienes dudas con la instalación, yo te ayudo a completarla.
                    </div>
                </div>
            </div>

        </div>
    </div>

  </div>
</section>

<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  gsap.registerPlugin(ScrollTrigger);

  const initScrollSequence = () => {
    // Initial 3D state for the phone
    gsap.set('.scroll-seq-phone', { 
        rotationY: -15, 
        rotationX: 5, 
        z: 0 
    });

    // Timeline
    const tl = gsap.timeline({
        scrollTrigger: {
            trigger: '#scroll-sequence',
            start: 'top top',
            end: '+=400%', // 4 screens worth of scroll
            scrub: 1,      // Smooth scrubbing
            pin: true,     // Pin the section
            anticipatePin: 1
        }
    });

    const mm = gsap.matchMedia();

    mm.add({
        isDesktop: "(min-width: 768px)",
        isMobile: "(max-width: 767px)"
    }, (context) => {
        let isDesktop = context.conditions ? (context.conditions as any).isDesktop : true;

        // --- TRANSITION TO SLIDE 2 ---
        tl.addLabel('slide2')
          // Crossfade Backgrounds
          .to('.seq-bg-1', { opacity: 0, duration: 1 }, 'slide2')
          .to('.seq-bg-2', { opacity: 1, duration: 1 }, 'slide2')
          
          // Animate Phone (2.5D effect)
          .to('.scroll-seq-phone', { 
              xPercent: isDesktop ? -70 : 0,  // Move left on desktop, stay center on mobile
              yPercent: isDesktop ? 0 : -30,  // Move up slightly on mobile
              rotationY: isDesktop ? 25 : 10,   // Rotate to face right
              rotationX: 10,
              rotationZ: -2,
              scale: isDesktop ? 0.9 : 0.8,
              z: -100, // push back slightly for depth
              boxShadow: "20px 30px 60px rgba(0,0,0,0.4)", // light shifts
              duration: 1,
              ease: "power2.inOut"
          }, 'slide2')
          
          // Crossfade Screens inside Phone
          .to('.phone-screen-1', { opacity: 0, duration: 0.5 }, 'slide2+=0.3')
          .to('.phone-screen-2', { opacity: 1, duration: 0.5 }, 'slide2+=0.3')
          
          // Pause reading time
          .to({}, { duration: 0.5 }); 


        // --- TRANSITION TO SLIDE 3 ---
        tl.addLabel('slide3')
          // Crossfade Backgrounds
          .to('.seq-bg-2', { opacity: 0, duration: 1 }, 'slide3')
          .to('.seq-bg-3', { opacity: 1, duration: 1 }, 'slide3')
          
          // Animate Phone (2.5D effect)
          .to('.scroll-seq-phone', { 
              xPercent: isDesktop ? 70 : 0,   // Move right on desktop
              yPercent: isDesktop ? 0 : 30,   // Move down on mobile
              rotationY: isDesktop ? -25 : -10,  // Rotate to face left
              rotationX: -5,
              rotationZ: 5,
              scale: isDesktop ? 1.05 : 0.9,
              z: 100, // pull forward
              boxShadow: "-30px 40px 80px rgba(0,0,0,0.6)",
              duration: 1,
              ease: "power2.inOut"
          }, 'slide3')
          
          // Crossfade Screens inside Phone
          .to('.phone-screen-2', { opacity: 0, duration: 0.5 }, 'slide3+=0.3')
          .to('.phone-screen-3', { opacity: 1, duration: 0.5 }, 'slide3+=0.3')

          // Pause reading time
          .to({}, { duration: 0.5 });
    });
  };

  // Run on mount
  initScrollSequence();
</script>
