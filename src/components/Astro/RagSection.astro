---
import { Brain, FileText, MessageSquareText } from 'lucide-react';
---
<section id="rag-section" class="relative bg-zinc-50 py-20 text-zinc-950 min-h-[300vh] border-b border-zinc-200">
  <!-- Sticky Container -->
  <div class="sticky top-0 h-[100dvh] w-full flex items-center justify-center px-6 overflow-hidden">
    <div class="max-w-[1400px] mx-auto w-full grid grid-cols-1 md:grid-cols-2 gap-12 lg:gap-24 items-center">
      
      <!-- Text Content (Left) -->
      <div class="space-y-12 relative h-64 md:h-96">
        
        <div id="rag-step-1" class="absolute inset-0 flex flex-col justify-center opacity-100">
          <div class="w-16 h-16 rounded-2xl bg-white flex items-center justify-center border border-zinc-200 mb-6 text-zinc-950 shadow-sm">
            <FileText size={32} strokeWidth={1.5} />
          </div>
          <h2 class="text-4xl md:text-5xl lg:text-6xl font-semibold mb-4 tracking-tight leading-[1.05]">Paso 1: Sube tus documentos.</h2>
          <p class="text-lg text-zinc-600 font-light">PDFs, manuales, bases de conocimiento. Kirovox procesa todo al instante sin configuraciones complejas.</p>
        </div>

        <div id="rag-step-2" class="absolute inset-0 flex flex-col justify-center opacity-0 translate-y-10">
          <div class="w-16 h-16 rounded-2xl bg-white flex items-center justify-center border border-zinc-200 mb-6 text-zinc-950 shadow-sm">
            <Brain size={32} strokeWidth={1.5} />
          </div>
          <h2 class="text-4xl md:text-5xl lg:text-6xl font-semibold mb-4 tracking-tight leading-[1.05]">Paso 2: La IA aprende.</h2>
          <p class="text-lg text-zinc-600 font-light">Nuestro motor indexa tu información para asegurar un contexto perfecto y evitar alucinaciones.</p>
        </div>

        <div id="rag-step-3" class="absolute inset-0 flex flex-col justify-center opacity-0 translate-y-10">
          <div class="w-16 h-16 rounded-2xl bg-white flex items-center justify-center border border-zinc-200 mb-6 text-zinc-950 shadow-sm">
            <MessageSquareText size={32} strokeWidth={1.5} />
          </div>
          <h2 class="text-4xl md:text-5xl lg:text-6xl font-semibold mb-4 tracking-tight leading-[1.05]">Paso 3: Respuestas perfectas.</h2>
          <p class="text-lg text-zinc-600 font-light">Atención 24/7 con respuestas precisas, siempre basadas en tu propia data técnica y comercial.</p>
        </div>

      </div>

      <!-- Visual Content (Right) -->
      <div class="relative h-[400px] w-full bg-white rounded-3xl border border-zinc-200 flex items-center justify-center overflow-hidden shadow-sm">
        
        <!-- Step 1 Graphic -->
        <div id="rag-graphic-1" class="absolute flex gap-4">
           <div class="w-20 h-24 bg-zinc-50 rounded-lg border border-zinc-200 flex items-center justify-center"><FileText className="text-zinc-400" strokeWidth={1} /></div>
           <div class="w-20 h-24 bg-white rounded-lg border border-zinc-200 shadow-sm flex items-center justify-center -translate-y-4"><FileText className="text-zinc-400" strokeWidth={1} /></div>
           <div class="w-20 h-24 bg-zinc-50 rounded-lg border border-zinc-200 flex items-center justify-center"><FileText className="text-zinc-400" strokeWidth={1} /></div>
        </div>

        <!-- Step 2 Graphic -->
        <div id="rag-graphic-2" class="absolute opacity-0 scale-90">
           <Brain size={120} className="text-zinc-950" strokeWidth={1} />
        </div>

        <!-- Step 3 Graphic -->
        <div id="rag-graphic-3" class="absolute opacity-0 scale-90 flex flex-col gap-4 w-3/4">
          <div class="bg-zinc-50 p-5 rounded-2xl rounded-tl-sm self-start max-w-[85%] border border-zinc-200">
            <p class="text-sm text-zinc-700">¿Cuáles son los horarios de atención?</p>
          </div>
          <div class="bg-zinc-950 p-5 rounded-2xl rounded-tr-sm self-end max-w-[85%] border border-zinc-800">
            <p class="text-sm text-zinc-100 font-light leading-relaxed">Atendemos de lunes a viernes de 9am a 6pm. ¡Estoy aquí para ayudarte 24/7!</p>
          </div>
        </div>

      </div>
    </div>
  </div>
</section>

<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  gsap.registerPlugin(ScrollTrigger);

  const initRagAnimations = () => {
    const tl = gsap.timeline({
      scrollTrigger: {
        trigger: '#rag-section',
        start: 'top top',
        end: 'bottom bottom',
        scrub: 1,
      }
    });

    // Fade out Step 1
    tl.to('#rag-step-1', { opacity: 0, y: -20, duration: 1 })
      .to('#rag-graphic-1', { opacity: 0, scale: 1.1, duration: 1 }, "<")
      
      // Fade in Step 2
      .to('#rag-step-2', { opacity: 1, y: 0, duration: 1 })
      .to('#rag-graphic-2', { opacity: 1, scale: 1, duration: 1 }, "<")
      
      // Hold Step 2
      .to({}, { duration: 1 })

      // Fade out Step 2
      .to('#rag-step-2', { opacity: 0, y: -20, duration: 1 })
      .to('#rag-graphic-2', { opacity: 0, scale: 1.1, duration: 1 }, "<")

      // Fade in Step 3
      .to('#rag-step-3', { opacity: 1, y: 0, duration: 1 })
      .to('#rag-graphic-3', { opacity: 1, scale: 1, duration: 1 }, "<")
      
      // Hold Step 3
      .to({}, { duration: 1 });
  };

  initRagAnimations();
</script>
