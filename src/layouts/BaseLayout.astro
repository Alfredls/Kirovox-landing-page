---
import '../styles/global.css';
import Button from '../components/Astro/Button.astro';

interface Props {
  title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="es" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content="Kirovox - La inteligencia artificial que transforma tu atención al cliente." />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon/favicon.ico" />
    <meta name="generator" content={Astro.generator} />
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Geist:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <title>{title}</title>
    <style>
      body { font-family: 'Geist', sans-serif; }
    </style>
  </head>
  <body class="bg-white text-zinc-950 min-h-screen selection:bg-emerald-500/30 selection:text-emerald-950">
    <nav class="fixed top-0 left-0 right-0 z-50 h-16 flex items-center justify-between px-6 bg-white/80 backdrop-blur-md border-b border-zinc-100">
      <div class="flex items-center gap-2">
        <img src="/logo.svg" alt="Kirovox Logo" class="h-8" />
        <span class="font-bold text-xl tracking-tight text-zinc-900">Kirovox</span>
      </div>
      <div class="flex items-center gap-4">
        <Button href="#demo" variant="ghost" size="sm" class="px-4 py-2 text-zinc-600 hover:text-zinc-950">Demo</Button>
        <Button href="#pricing" variant="primary" size="sm" class="px-5 py-2">Empezar</Button>
      </div>
    </nav>

    <slot />

    <footer class="py-12 border-t border-zinc-200 mt-20 text-center text-zinc-500 text-sm bg-white">
      <div class="flex justify-center items-center gap-2 mb-4">
        <img src="/logo.svg" alt="Kirovox Logo" class="h-6 opacity-70 hover:opacity-100 transition-opacity grayscale hover:grayscale-0" />
      </div>
      <p>&copy; {new Date().getFullYear()} Kirovox. Todos los derechos reservados.</p>
    </footer>
  </body>
</html>
